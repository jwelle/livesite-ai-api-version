{
  "manifest_version": 3,
  "name": "LiveSite AI Demo Builder",
  "version": "0.1.0",
  "description": "Create LiveSite AI demo links from the current prospect page.",
  "action": {
    "default_title": "LiveSite AI Demo Builder",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "service_worker.js"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://*.vercel.app/*",
    "https://livesiteai.com/*",
    "https://*.livesiteai.com/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
